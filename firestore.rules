rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- reusable helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.email == "mateus.silvamx75@gmail.com"
      );
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == "mateus.silvamx75@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidEvent(data) {
      return data.keys().hasAll(['id', 'organizacaoId', 'nome', 'local', 'data', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.organizacaoId is string && data.organizacaoId.size() <= 128
        && data.nome is string && data.nome.size() <= 200
        && data.local is string && data.local.size() <= 300
        && data.data is string && data.data.size() <= 50
        && data.status in ['preparacao', 'ativo', 'encerrado'];
    }

    function isValidScore(data) {
      return data.keys().hasAll(['id', 'eventoId', 'categoryId', 'participanteId', 'juradoId', 'timestamp'])
        && data.id is string && data.id.size() <= 128
        && data.eventoId is string && data.eventoId.size() <= 128
        && data.categoryId is string && data.categoryId.size() <= 128
        && data.participanteId is string && data.participanteId.size() <= 128
        && data.juradoId is string && data.juradoId.size() <= 128
        && data.timestamp is string && data.timestamp.size() <= 100
        && (!data.keys().contains('comentario') || (data.comentario is string && data.comentario.size() <= 1000))
        && (!data.keys().contains('dispositivoInfo') || (data.dispositivoInfo is string && data.dispositivoInfo.size() <= 200));
    }

    function isValidStageState(data) {
      return data.keys().hasAll(['currentEventId', 'currentCategoryId', 'screenState', 'timerCount', 'timerActive'])
        && data.currentEventId is string && data.currentEventId.size() <= 128
        && data.currentCategoryId is string && data.currentCategoryId.size() <= 128
        && data.screenState is string && data.screenState.size() <= 50
        && data.timerCount is number
        && data.timerActive is bool;
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['id', 'timestamp', 'usuario', 'papel', 'acao', 'detalhes'])
        && data.id is string && data.id.size() <= 128
        && data.timestamp is string && data.timestamp.size() <= 100
        && data.usuario is string && data.usuario.size() <= 100
        && data.papel is string && data.papel.size() <= 50
        && data.acao is string && data.acao.size() <= 100
        && data.detalhes is string && data.detalhes.size() <= 2000;
    }

    // --- Collection Routes ---
    match /events/{eventId} {
      allow read: if true; // Event schedules are public so telão and guests can view them
      allow create, update: if isAdmin() && isValidId(eventId) && isValidEvent(incoming());
      allow delete: if isAdmin() && isValidId(eventId);
    }

    match /scores/{scoreId} {
      allow read: if true; // Scores are public for calculations on the telão and admin
      allow create: if isEmailVerified() && isValidId(scoreId) && isValidScore(incoming());
      allow update: if isEmailVerified() && isValidId(scoreId) && isValidScore(incoming()) && (
        isAdmin() || (existing().juradoId == request.auth.uid && incoming().juradoId == existing().juradoId)
      );
      allow delete: if isAdmin() && isValidId(scoreId);
    }

    match /stageState/{docId} {
      allow read: if true;
      allow create, update: if isEmailVerified() && isValidId(docId) && isValidStageState(incoming());
      allow delete: if isAdmin() && isValidId(docId);
    }

    match /auditLogs/{logId} {
      allow read: if isEmailVerified();
      allow create: if isEmailVerified() && isValidId(logId) && isValidAuditLog(incoming());
      allow update, delete: if false; // Audit logs are immutable once written to protect integrity
    }
  }
}
